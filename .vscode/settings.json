{
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },

    "python.analysis.typeCheckingMode": "basic",
    
    "notebook.output.scrolling": true,
    "notebook.output.textLineLimit": 30,
    "notebook.diff.ignoreOutputs": false,
    "interactiveWindow.collapseCellInputCode": "never",

    "workbench.colorCustomizations": {
        "activityBar.activeBackground": "#3b1e59",
        "activityBar.background": "#3b1e59",
        "activityBar.foreground": "#e7e7e7",
        "activityBar.inactiveForeground": "#e7e7e799",
        "activityBarBadge.background": "#8f5f30",
        "activityBarBadge.foreground": "#e7e7e7",
        "commandCenter.border": "#e7e7e799",
        "sash.hoverBorder": "#3b1e59",
        "statusBar.background": "#221133",
        "statusBar.foreground": "#e7e7e7",
        "statusBarItem.hoverBackground": "#3b1e59",
        "statusBarItem.remoteBackground": "#221133",
        "statusBarItem.remoteForeground": "#e7e7e7",
        "titleBar.activeBackground": "#221133",
        "titleBar.activeForeground": "#e7e7e7",
        "titleBar.inactiveBackground": "#22113399",
        "titleBar.inactiveForeground": "#e7e7e799"
    },
    "peacock.color": "#221133FF"
}